<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/eventListFragment">

    <fragment
        android:id="@+id/eventListFragment"
        android:name="com.example.personalplanner.ui.EventListFragment"
        android:label="Event List">
        <action
            android:id="@+id/action_eventListFragment_to_editEventFragment"
            app:destination="@id/editEventFragment" />
    </fragment>

    <fragment
        android:id="@+id/addEventFragment"
        android:name="com.example.personalplanner.ui.AddEventFragment"
        android:label="Add Event" />

    <fragment
        android:id="@+id/editEventFragment"
        android:name="com.example.personalplanner.ui.EditEventFragment"
        android:label="Edit Event">
        <argument
            android:name="eventId"
            app:argType="integer" />
    </fragment>
</navigation>